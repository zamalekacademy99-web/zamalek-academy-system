{
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm install && npx prisma generate && npx tsc --project tsconfig.json"
    },
    "deploy": {
        "startCommand": "node dist/server.js",
        "healthcheckPath": "/api/v1/health",
        "restartPolicyType": "ON_FAILURE"
    }
}